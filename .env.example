# FortiManager connection for scripts/capture_fixtures.py.
# Copy to .env and fill in. Pick ONE auth method.

FMG_HOST=fmg.example.com
FMG_ADOM=my-test-adom
FMG_VERIFY_SSL=true

# (A) API token — Bearer auth.
# FMG_API_KEY=changeme

# (B) User / password — classic /sys/login/user.
FMG_USERNAME=admin
FMG_PASSWORD=changeme
